# Source API the worker polls for peg-in / deposit state (must match your stack).
BACKEND_BASE_URL="http://localhost:8080"
BACKEND_DEPOSITS_PATH="/peg-ins"

POLL_INTERVAL_MS=5000

# Where signed webhooks are POSTed — e.g. examples/wallet-backend or examples/exchange-processor.
WEBHOOK_ENDPOINT_URL="http://localhost:3001/webhooks"
WEBHOOK_SECRET="change-me"
WEBHOOK_EVENT_NAME="rbtc.peg_in"
WEBHOOK_EVENT_VERSION="1"

RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_MS=1000
RETRY_MULTIPLIER=2

STORAGE_MODE="sqlite"
STORAGE_PATH="./data/rbtc-eventkit.sqlite"

LOG_LEVEL="info"
