# Backend adapter: "generic" (JSON mock / custom gateway) or "twoWp" (rsksmart/2wp-api observer).
# See docs/two-wp-api.md for the pinned 2wp-api contract (v3.3.1).
BACKEND_ADAPTER="generic"

# Backend (source of truth)
# — generic: base URL + path below (e.g. local mock peg-in server; not Rootstock production).
# — twoWp: set to your 2wp-api base URL, OR leave unset and use TWO_WP_BASE_URL instead.
BACKEND_BASE_URL="http://localhost:8080"
BACKEND_DEPOSITS_PATH="/peg-ins"

# TwoWp (2wp-api) — required when BACKEND_ADAPTER=twoWp
# TWO_WP_BASE_URL="https://your-2wp-api-host"   # optional; if unset, BACKEND_BASE_URL is used
TWO_WP_TRACKED_ADDRESS=""
# TWO_WP_HISTORY_PAGE=1
# TWO_WP_STATUS_CONCURRENCY=4

# Worker loop
POLL_INTERVAL_MS=5000

# Webhook delivery
WEBHOOK_ENDPOINT_URL="http://localhost:3001/webhooks"
WEBHOOK_SECRET="change-me"
WEBHOOK_EVENT_NAME="rbtc.peg_in"
WEBHOOK_EVENT_VERSION="1"

# Retries
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_MS=1000
RETRY_MULTIPLIER=2

# Persistence
STORAGE_MODE="sqlite"
STORAGE_PATH="./data/rbtc-eventkit.sqlite"

# Logging
LOG_LEVEL="info"

